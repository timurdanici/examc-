        #region REPORTS TAB

        private void btnGenerateReport_Click(object sender, EventArgs e)
        {
            try
            {
                DataTable dt = null;

                switch (cmbReportType.SelectedIndex)
                {
                    case 0: // All Products
                        dt = _productRepo.GetAll();
                        break;
                    case 1: // Products by Category
                        dt = _categoryRepo.GetAll();
                        break;
                    case 2: // Products by Supplier
                        dt = _supplierRepo.GetAll();
                        break;
                    case 3: // All Categories
                        dt = _categoryRepo.GetAll();
                        break;
                    case 4: // All Suppliers
                        dt = _supplierRepo.GetAll();
                        break;
                }

                if (dt == null || dt.Rows.Count == 0)
                {
                    MessageBox.Show("No data found.", "Info", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    dgvReports.DataSource = null;
                }
                else
                {
                    dgvReports.DataSource = dt;
                    dgvReports.AutoResizeColumns();
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Error: " + ex.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

