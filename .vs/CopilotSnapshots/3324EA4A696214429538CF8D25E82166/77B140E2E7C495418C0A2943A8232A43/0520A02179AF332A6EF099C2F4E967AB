using exam.Database;
using exam.Models;
using System;
using System.Collections.Generic;
using System.Data;

namespace exam.Services
{
    /// <summary>
    /// Repository class for Product CRUD operations
    /// </summary>
    public class ProductRepository
    {
        private DatabaseConnection _db;

        public ProductRepository()
        {
            _db = new DatabaseConnection();
        }

        /// <summary>
        /// Get all products from database
        /// </summary>
        public DataTable GetAll()
        {
            try
            {
                string query = "SELECT ProductID, ProductName, Category, Price, Quantity, CreatedDate FROM Products ORDER BY ProductID DESC";
                return _db.ExecuteSelect(query);
            }
            catch (Exception ex)
            {
                throw new Exception("Error retrieving products: " + ex.Message);
            }
        }

        /// <summary>
        /// Add new product to database
        /// </summary>
        public bool Add(Product product)
        {
            try
            {
                string query = $"INSERT INTO Products (ProductName, Category, Price, Quantity, CreatedDate) " +
                    $"VALUES ('{product.ProductName}', '{product.Category}', {product.Price}, {product.Quantity}, NOW())";
                return _db.ExecuteNonQuery(query);
            }
            catch (Exception ex)
            {
                throw new Exception("Error adding product: " + ex.Message);
            }
        }

        /// <summary>
        /// Update existing product
        /// </summary>
        public bool Update(Product product)
        {
            try
            {
                string query = $"UPDATE Products SET ProductName = '{product.ProductName}', " +
                    $"Category = '{product.Category}', Price = {product.Price}, Quantity = {product.Quantity} " +
                    $"WHERE ProductID = {product.ProductID}";
                return _db.ExecuteNonQuery(query);
            }
            catch (Exception ex)
            {
                throw new Exception("Error updating product: " + ex.Message);
            }
        }

        /// <summary>
        /// Delete product by ID
        /// </summary>
        public bool Delete(int productID)
        {
            try
            {
                string query = $"DELETE FROM Products WHERE ProductID = {productID}";
                return _db.ExecuteNonQuery(query);
            }
            catch (Exception ex)
            {
                throw new Exception("Error deleting product: " + ex.Message);
            }
        }

        /// <summary>
        /// Search products by keyword
        /// </summary>
        public DataTable Search(string keyword)
        {
            try
            {
                string query = $"SELECT ProductID, ProductName, Category, Price, Quantity, CreatedDate FROM Products " +
                    $"WHERE ProductName LIKE '%{keyword}%' OR Category LIKE '%{keyword}%' ORDER BY ProductID DESC";
                return _db.ExecuteSelect(query);
            }
            catch (Exception ex)
            {
                throw new Exception("Error searching products: " + ex.Message);
            }
        }

        /// <summary>
        /// Get products by category
        /// </summary>
        public DataTable GetByCategory(string category)
        {
            try
            {
                string query = $"SELECT ProductID, ProductName, Category, Price, Quantity, CreatedDate FROM Products " +
                    $"WHERE Category = '{category}' ORDER BY ProductID DESC";
                return _db.ExecuteSelect(query);
            }
            catch (Exception ex)
            {
                throw new Exception("Error filtering by category: " + ex.Message);
            }
        }

        /// <summary>
        /// Get all unique categories
        /// </summary>
        public DataTable GetAllCategories()
        {
            try
            {
                string query = "SELECT DISTINCT Category FROM Products ORDER BY Category";
                return _db.ExecuteSelect(query);
            }
            catch (Exception ex)
            {
                throw new Exception("Error retrieving categories: " + ex.Message);
            }
        }

        /// <summary>
        /// Get product by ID
        /// </summary>
        public DataTable GetByID(int productID)
        {
            try
            {
                string query = $"SELECT ProductID, ProductName, Category, Price, Quantity, CreatedDate FROM Products WHERE ProductID = {productID}";
                return _db.ExecuteSelect(query);
            }
            catch (Exception ex)
            {
                throw new Exception("Error retrieving product: " + ex.Message);
            }
        }
    }
}
